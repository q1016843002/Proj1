package com.yourcompany.business.entity;

import com.yourcompany.audit.annotation.AuditMeta;
import com.fasterxml.jackson.annotation.JsonCreator;
import com.fasterxml.jackson.annotation.JsonIgnoreProperties;
import lombok.Data;
import lombok.NoArgsConstructor;
import lombok.AllArgsConstructor;
import org.javers.core.metamodel.annotation.Id;
import org.javers.core.metamodel.annotation.DiffIgnore;

@Data
@NoArgsConstructor
@AllArgsConstructor
@JsonIgnoreProperties(ignoreUnknown = true)
public class FeeBillingFund {

    @Id // 💥 必须有：告诉 Javers 这是一个可追踪的独立实体
    private String id; 

    @AuditMeta(displayName = "Fund Name", tabName = "Fund List")
    private String fundName;

    @AuditMeta(displayName = "Fund Code", tabName = "Fund List")
    private String fundCode;

    @AuditMeta(displayName = "Cash Account", tabName = "Fund List")
    private String cashAccount;

    @AuditMeta(displayName = "Effective Date From", tabName = "Fund List")
    private String effectiveDateFrom;

    @AuditMeta(displayName = "Effective Date To", tabName = "Fund List")
    private String effectiveDateTo;

    @AuditMeta(displayName = "VAT Status", tabName = "Fund List")
    private VatStatus vatStatus;

    @AuditMeta(displayName = "VAT Location", tabName = "Fund List")
    private VatLocation vatLocation;

    @AuditMeta(displayName = "Invoice Group", tabName = "Fund List")
    private String invoiceGroup;

    @DiffIgnore // 过滤系统垃圾日志
    private String serviceChangeLogId; 

    // =========================================================
    // 💥 内部枚举 1：VatStatus
    // =========================================================
    public enum VatStatus {
        QUALIFYING("Qualifying"),
        NON_QUALIFYING("Non-Qualifying"),
        UNKNOWN("-");

        private final String displayValue;

        VatStatus(String displayValue) { this.displayValue = displayValue; }

        @Override
        public String toString() { return this.displayValue; }

        @JsonCreator
        public static VatStatus fromString(String rawValue) {
            if (rawValue == null || rawValue.trim().isEmpty()) return null;
            for (VatStatus status : VatStatus.values()) {
                if (status.name().equalsIgnoreCase(rawValue)) return status;
            }
            return UNKNOWN;
        }
    }

    // =========================================================
    // 💥 内部枚举 2：VatLocation
    // =========================================================
    public enum VatLocation {
        UK("UK"),
        NON_UK("Non-UK"),
        UNKNOWN("-");

        private final String displayValue;

        VatLocation(String displayValue) { this.displayValue = displayValue; }

        @Override
        public String toString() { return this.displayValue; }

        @JsonCreator
        public static VatLocation fromString(String rawValue) {
            if (rawValue == null || rawValue.trim().isEmpty()) return null;
            for (VatLocation location : VatLocation.values()) {
                if (location.name().equalsIgnoreCase(rawValue)) return location;
            }
            return UNKNOWN;
        }
    }
}

package com.yourcompany.audit.service;

import com.yourcompany.audit.annotation.AuditMeta;
import com.yourcompany.business.entity.ClientEntity;
import com.yourcompany.business.entity.FeeBillingFund;
import org.javers.core.diff.changetype.PropertyChange;
import org.javers.core.diff.changetype.ValueChange;
import org.springframework.stereotype.Service;

@Service
public class FeeBillingFundAuditService {

    /**
     * 专属处理入口
     */
    public void processFundChange(String operator, PropertyChange change, AuditMeta meta, 
                                  String targetId, ClientEntity oldEntity, ClientEntity newEntity) {
        
        // 1. 找对象：去实体里老老实实把这个 Fund 捞出来
        FeeBillingFund fund = findFeeBillingFund(targetId, oldEntity, newEntity);
        if (fund == null) return;

        // 2. 核心格式装配 (严格按照你的需求)
        String tabName = "Fund List"; 
        String fCode = fund.getFundCode() != null ? fund.getFundCode() : "N/A";
        String fieldLocation = "Fund code - " + fCode; 
        String changedField = meta.displayName(); 
        
        // 3. 提取新旧值（Fund 里面的都是简单值或枚举，直接从 Javers 拿最快）
        String oldVal = "-";
        String newVal = "-";
        if (change instanceof ValueChange) {
            ValueChange vc = (ValueChange) change;
            oldVal = vc.getLeft() != null ? vc.getLeft().toString() : "-";
            newVal = vc.getRight() != null ? vc.getRight().toString() : "-";
        } 

        // 4. 落库
        saveToDatabase(operator, tabName, fieldLocation, changedField, oldVal, newVal);
    }

    /**
     * 笨办法：遍历找对象
     */
    private FeeBillingFund findFeeBillingFund(String targetId, ClientEntity oldEntity, ClientEntity newEntity) {
        if (newEntity != null && newEntity.getFeeBillingFunds() != null) {
            for (FeeBillingFund fund : newEntity.getFeeBillingFunds()) {
                if (targetId.equals(fund.getId())) return fund;
            }
        }
        if (oldEntity != null && oldEntity.getFeeBillingFunds() != null) {
            for (FeeBillingFund fund : oldEntity.getFeeBillingFunds()) {
                if (targetId.equals(fund.getId())) return fund;
            }
        }
        return null;
    }

    /**
     * 模拟落库方法 (你需要替换成你真实的 Mapper/Repository 调用)
     */
    private void saveToDatabase(String operator, String tabName, String fieldLocation, 
                                String changedField, String oldVal, String newVal) {
        System.out.println(String.format("【保存日志】Tab: %s | Loc: %s | Field: %s | Old: %s -> New: %s", 
                tabName, fieldLocation, changedField, oldVal, newVal));
    }
}

package com.yourcompany.audit.service;

import com.yourcompany.audit.annotation.AuditMeta;
import com.yourcompany.business.entity.ClientEntity;
import org.javers.core.Javers;
import org.javers.core.diff.Diff;
import org.javers.core.diff.changetype.PropertyChange;
import org.javers.core.metamodel.object.InstanceId;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.lang.reflect.Field;
import java.util.List;

@Service
public class EntityAuditService {

    @Autowired
    private Javers javers;

    // 💥 注入刚才写好的专属子服务
    @Autowired
    private FeeBillingFundAuditService feeBillingFundAuditService;

    public void processEntityAudit(String operator, ClientEntity oldEntity, ClientEntity newEntity) {
        if (oldEntity == null || newEntity == null) return;

        // 启动核心比对
        Diff diff = javers.compare(oldEntity, newEntity);
        List<PropertyChange> changes = diff.getChangesByType(PropertyChange.class);

        for (PropertyChange change : changes) {
            AuditMeta meta = getAuditMetaFromChange(change); 
            if (meta == null) continue; // 拦截网，没有注解的直接丢弃

            String className = change.getAffectedGlobalId().typeName();
            Object cdoId = null;
            if (change.getAffectedGlobalId() instanceof InstanceId) {
                cdoId = ((InstanceId) change.getAffectedGlobalId()).getCdoId();
            }

            // =========================================================
            // 💥 路由分发中心
            // =========================================================
            
            // 路由 1：如果是 FeeBillingFund 的字段变了，甩给专属小弟处理！
            if (className != null && className.endsWith("FeeBillingFund") && cdoId != null) {
                feeBillingFundAuditService.processFundChange(
                        operator, change, meta, cdoId.toString(), oldEntity, newEntity
                );
                continue; // 处理完毕，直接 continue 跳到下一个差异
            }

            // 路由 2：未来如果有 InvoiceGroup，继续加 else if 路由...
            
            // =========================================================
            // 默认兜底处理（处理 ClientEntity 本身最外层的普通字段）
            // =========================================================
            handleDefaultChange(operator, change, meta); 
        }
    }

    private void handleDefaultChange(String operator, PropertyChange change, AuditMeta meta) {
        // ... 你最开始写的那个针对普通字段的极简处理逻辑 ...
        // 例如：直接拼装 displayName，然后调用 saveToDatabase
    }

    // =====================================================================
    // 反射辅助工具库 (我们之前写好的工业级防弹版反射)
    // =====================================================================
    private AuditMeta getAuditMetaFromChange(PropertyChange change) {
        try {
            String className = change.getAffectedGlobalId().typeName();
            if (className.contains("$")) {
                className = className.substring(0, className.indexOf("$")); // 剥离代理类
            }
            Class<?> affectedClass = Class.forName(className);
            Field field = getFieldAcrossHierarchy(affectedClass, change.getPropertyName());
            if (field != null) {
                return field.getAnnotation(AuditMeta.class);
            }
        } catch (Exception e) {
            // 静默处理或打印警告
        }
        return null;
    }

    private Field getFieldAcrossHierarchy(Class<?> clazz, String fieldName) {
        while (clazz != null && clazz != Object.class) {
            try {
                return clazz.getDeclaredField(fieldName);
            } catch (NoSuchFieldException e) {
                clazz = clazz.getSuperclass();
            }
        }
        return null;
    }
}
