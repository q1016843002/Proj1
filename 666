package com.yourcompany.audit.service;

import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.yourcompany.audit.annotation.AuditMeta;
import com.yourcompany.business.entity.FeeAdjustmentForAuditTrail;
import org.javers.core.Javers;
import org.javers.core.diff.Diff;
import org.javers.core.diff.changetype.PropertyChange;
import org.javers.core.diff.changetype.ValueChange;
import org.javers.core.metamodel.object.InstanceId;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.lang.reflect.Field;
import java.util.ArrayList;
import java.util.List;

@Service
public class FeeAdjustmentAuditTrailService {

    @Autowired
    private ObjectMapper objectMapper;

    @Autowired
    private Javers javers;

    /**
     * 业务入口：处理 Fee Adjustment 模块的审计
     */
    public void processFeeAdjustmentAudit(String operator, String oldJson, String newJson) {
        try {
            List<FeeAdjustmentForAuditTrail> oldProducts = objectMapper.readValue(oldJson, new TypeReference<List<FeeAdjustmentForAuditTrail>>() {});
            List<FeeAdjustmentForAuditTrail> newProducts = objectMapper.readValue(newJson, new TypeReference<List<FeeAdjustmentForAuditTrail>>() {});

            // 压平不同 Tab 下的所有 Services
            List<FeeAdjustmentForAuditTrail.ConfigService> oldFlat = flatten(oldProducts);
            List<FeeAdjustmentForAuditTrail.ConfigService> newFlat = flatten(newProducts);

            Diff diff = javers.compareCollections(oldFlat, newFlat, FeeAdjustmentForAuditTrail.ConfigService.class);
            List<PropertyChange> changes = diff.getChangesByType(PropertyChange.class);

            for (PropertyChange change : changes) {
                AuditMeta meta = getAuditMetaFromChange(change);
                if (meta == null) continue;

                String targetId = ((InstanceId) change.getAffectedGlobalId()).getCdoId().toString();
                FeeAdjustmentForAuditTrail.ConfigService service = find(targetId, oldFlat, newFlat);
                if (service == null) continue;

                // 提取清洗好的审计字段
                String tabName = service.getParentTabName();
                String fieldLocation = service.getAuditFieldLocation();
                String changedField = meta.displayName();

                String oldVal = "-";
                String newVal = "-";
                if (change instanceof ValueChange) {
                    ValueChange vc = (ValueChange) change;
                    oldVal = vc.getLeft() != null ? vc.getLeft().toString() : "-";
                    newVal = vc.getRight() != null ? vc.getRight().toString() : "-";
                }

                saveToDatabase(operator, tabName, fieldLocation, changedField, oldVal, newVal);
            }
        } catch (Exception e) {
            System.err.println("FeeAdjustment 审计失败: " + e.getMessage());
        }
    }

    private List<FeeAdjustmentForAuditTrail.ConfigService> flatten(List<FeeAdjustmentForAuditTrail> products) {
        List<FeeAdjustmentForAuditTrail.ConfigService> flatList = new ArrayList<>();
        if (products == null) return flatList;
        for (FeeAdjustmentForAuditTrail p : products) {
            if (p.getServices() == null) continue;
            for (FeeAdjustmentForAuditTrail.ConfigService s : p.getServices()) {
                s.flattenForAudit(p.getName()); // 注入 TabName 并触发清洗
                flatList.add(s);
            }
        }
        return flatList;
    }

    private FeeAdjustmentForAuditTrail.ConfigService find(String id, List<FeeAdjustmentForAuditTrail.ConfigService> l1, List<FeeAdjustmentForAuditTrail.ConfigService> l2) {
        for (FeeAdjustmentForAuditTrail.ConfigService s : l2) if (id.equals(s.getServiceId())) return s;
        for (FeeAdjustmentForAuditTrail.ConfigService s : l1) if (id.equals(s.getServiceId())) return s;
        return null;
    }

    private AuditMeta getAuditMetaFromChange(PropertyChange change) {
        try {
            String className = change.getAffectedGlobalId().typeName();
            if (className.contains("$$")) className = className.substring(0, className.indexOf("$$"));
            Class<?> affectedClass = Class.forName(className);
            Field field = getFieldAcrossHierarchy(affectedClass, change.getPropertyName());
            return field != null ? field.getAnnotation(AuditMeta.class) : null;
        } catch (Exception e) { return null; }
    }

    private Field getFieldAcrossHierarchy(Class<?> clazz, String fieldName) {
        while (clazz != null && clazz != Object.class) {
            try { return clazz.getDeclaredField(fieldName); } 
            catch (NoSuchFieldException e) { clazz = clazz.getSuperclass(); }
        }
        return null;
    }

    private void saveToDatabase(String op, String tab, String loc, String field, String oldV, String newV) {
        System.out.println(String.format("【%s】%s | %s | %s: %s -> %s", op, tab, loc, field, oldV, newV));
    }
}
